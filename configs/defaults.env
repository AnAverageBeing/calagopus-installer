# Calagopus Installer - default configuration profile.
# Sourced by src/lib/config.sh as the baseline before user overrides.
# Every value here is a safe default; the interactive prompts override them.

DEPLOY_MODE=docker
RELEASE_CHANNEL=stable
INSTALL_TARGET=panel

PANEL_PORT=8000
WINGS_PORT=443
VARIANT=latest

DB_REMOTE=local
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=panel
DB_USER=calagopus

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_MODE=redis

PROXY_ENGINE=nginx
SSL_PROVIDER=letsencrypt
FIREWALL_ENGINE=ufw

BACKUP_SCHEDULE=daily
BACKUP_RETENTION=7
