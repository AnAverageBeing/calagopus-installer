# Calagopus Panel environment configuration.
# Generated by the Calagopus Installer. Sourced by the panel binary / compose.
# Variables marked CHANGEME are substituted at install time; the rest are
# safe defaults you can tune later.

# --- Required ---------------------------------------------------------------
# Encryption key for stored secrets. NEVER lose this. Rotating requires
# re-encrypting all stored secrets.
APP_ENCRYPTION_KEY=${APP_ENCRYPTION_KEY}

# PostgreSQL connection URL. The credentials must be able to create tables
# and run migrations.
DATABASE_URL=${DATABASE_URL}

# --- Caching ----------------------------------------------------------------
# Redis/Valkey connection. Falls back to in-memory cache if unset.
REDIS_URL=${REDIS_URL}

# --- Network ----------------------------------------------------------------
BIND=${BIND}
PORT=${PORT}

# --- Application behaviour --------------------------------------------------
APP_DEBUG=${APP_DEBUG}
APP_PRIMARY=true
APP_USE_INTERNAL_CACHE=true
APP_ENABLE_WINGS_PROXY=false
DATABASE_MIGRATE=true

# --- Identification ---------------------------------------------------------
SERVER_NAME=${SERVER_NAME}
