# Calagopus Panel environment - upstream example (fallback template).
# This mirrors https://github.com/calagopus/panel/blob/main/.env.example
# and is used when the rendered template is unavailable.

APP_ENCRYPTION_KEY=${APP_ENCRYPTION_KEY}
DATABASE_URL=${DATABASE_URL}
REDIS_URL=${REDIS_URL}
BIND=${BIND}
PORT=${PORT}
APP_DEBUG=${APP_DEBUG}
APP_PRIMARY=true
APP_USE_INTERNAL_CACHE=true
APP_ENABLE_WINGS_PROXY=false
DATABASE_MIGRATE=true
SERVER_NAME=${SERVER_NAME}
